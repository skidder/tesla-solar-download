# Tesla Solar Download Configuration
# Copy this file to .env and fill in your values

# Tesla account email (required)
TESLA_EMAIL=your_tesla_email@example.com

# MQTT Settings for Home Assistant
MQTT_ENABLED=true
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=tesla_solar

# Home Assistant MQTT Discovery (auto-configure sensors)
HA_DISCOVERY_ENABLED=true
MQTT_DISCOVERY_PREFIX=homeassistant

# InfluxDB Settings (for historical data - recommended for backfill)
INFLUXDB_ENABLED=false
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_ORG=home
INFLUXDB_BUCKET=tesla_solar

# Data directory (default: ./download)
# DATA_DIR=/path/to/data

# Logging
LOG_LEVEL=INFO
# LOG_FILE=/var/log/tesla-solar.log

# Debug mode
DEBUG=false

